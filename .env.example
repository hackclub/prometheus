SLACK_USER_TOKEN=xoxp-user-token-here
SLACK_SIGNING_SECRET=your-signing-secret
SLACK_APP_TOKEN=xapp-your-app-token
SLACK_BOT_TOKEN=xoxb-your-bot-token

# default admins
SUPERADMINS=U12345678,U87654321

# logging
LOG_CHANNEL=C12345678
HACKCLUB_CDN_KEY=sk_cdn_your_key_here

# slack mod tools (enterprise only)
# browser token (xoxc-...) and session cookie for undocumented moderation APIs
SLACK_BROWSER_TOKEN=xoxc-your-browser-token
SLACK_COOKIE=xoxd-d-cookie-value
